# 복사 후 .env.local 로 저장하고 실제 키 입력
# Vite는 .env.local 을 Git에 올리지 않습니다 (*.local)

VITE_SAFEMAP_SERVICE_KEY=여기에_인증키

# (선택) 요약 JSON을 Vercel이 아닌 URL에서만 받을 때 — 절대 URL. 설정 시 vercel.json CSP connect-src에 호스트 추가 필요
# VITE_EV_STATIONS_SUMMARY_URL=https://example.com/ev-stations-summary.json

# CI(GitHub Actions 등)에서는 동일 값을 SAFEMAP_SERVICE_KEY 로도 넣을 수 있음
# (scripts/build-ev-stations-summary.mjs 가 둘 다 읽음)
